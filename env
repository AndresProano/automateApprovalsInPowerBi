# --- OAuth de TU API (client credentials) ---
# Identidad de tu app (para Device Code o client secret)
TENANT_ID=
CLIENT_ID=

# Escopos (elige uno)
SCOPE=https://graph.microsoft.com/.default
# SCOPE=User.Read   # si quieres algo más mínimo

# === MODO 1: Access token proporcionado ===
# Si lo pasas por --env ACCESS_TOKEN, el contenedor lo usará tal cual
ACCESS_TOKEN=
# === MODO 2: Device Code (sin secret) ===
# Pon DEVICE_CODE=1 para disparar device flow y cachear el token
DEVICE_CODE=

# === MODO 3: Client credentials (opcional, si algún día lo usas) ===
CLIENT_SECRET=

# Resto (fuentes/destinos). Si solo vas a leer, con esto basta:
LOG_LEVEL=INFO

# --- Correo de salida (lo más simple) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=<<>>
SMTP_PASS=<<>>
MAIL_FROM=<<>>
MAIL_TO=<<>>
MAIL_SUBJECT=Approvals CSV